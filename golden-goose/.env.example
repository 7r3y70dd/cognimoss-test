# Flask Configuration
FLASK_APP=app.py
FLASK_ENV=development
FLASK_DEBUG=true

# Secret Key (generate a secure random key for production)
SECRET_KEY=your-secret-key-here

# Database URL
# SQLite (default)
DATABASE_URL=sqlite:///app.db

# PostgreSQL example
# DATABASE_URL=postgresql://username:password@localhost/golden_goose

# MySQL example
# DATABASE_URL=mysql://username:password@localhost/golden_goose

# Stock API Configuration
# Get a free API key from https://www.alphavantage.co/support/#api-key
STOCK_API_KEY=your-alpha-vantage-api-key-here
STOCK_API_PROVIDER=alphavantage

# Alternative providers (not yet implemented):
# STOCK_API_PROVIDER=finnhub
# STOCK_API_KEY=your-finnhub-api-key
